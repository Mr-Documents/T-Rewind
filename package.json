{
  "name": "vscode-time-travel",
  "displayName": "Time-Travel Debugger",
  "description": "Professional-grade VS Code extension for continuous, visual code history tracking with time-travel debugging.",
  "version": "0.0.1",
  "publisher": "time-travel-team",
  "icon": "assets/icon.png",
  "engines": {
    "vscode": "^1.80.0"
  },
  "categories": [
    "Other"
  ],
  "activationEvents": [],
  "main": "./dist/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "time-travel.startRecording",
        "title": "Time-Travel: Start Recording",
        "icon": "$(record)"
      },
      {
        "command": "time-travel.stopRecording",
        "title": "Time-Travel: Stop Recording",
        "icon": "$(stop)"
      },
      {
        "command": "time-travel.openTimeline",
        "title": "Time-Travel: Open Timeline"
      },
      {
        "command": "time-travel.exportSession",
        "title": "Time-Travel: Export Session",
        "icon": "$(export)"
      },
      {
        "command": "time-travel.importSession",
        "title": "Time-Travel: Import Session",
        "icon": "$(import)"
      }
    ],
    "keybindings": [
      {
        "command": "time-travel.startRecording",
        "key": "ctrl+shift+r",
        "mac": "cmd+shift+r",
        "when": "!time-travel:recording"
      },
      {
        "command": "time-travel.stopRecording",
        "key": "ctrl+shift+s",
        "mac": "cmd+shift+s",
        "when": "time-travel:recording"
      },
      {
        "command": "time-travel.openTimeline",
        "key": "ctrl+shift+t",
        "mac": "cmd+shift+t"
      }
    ],
    "viewsContainers": {
      "panel": [
        {
          "id": "time-travel-explorer",
          "title": "Time-Travel",
          "icon": "$(history)"
        }
      ]
    },
    "views": {
      "time-travel-explorer": [
        {
          "type": "webview",
          "id": "time-travel-timeline",
          "name": "Timeline"
        }
      ]
    },
    "menus": {
      "commandPalette": [
        {
          "command": "time-travel.startRecording",
          "when": "!time-travel:recording"
        },
        {
          "command": "time-travel.stopRecording",
          "when": "time-travel:recording"
        }
      ],
      "view/title": [
        {
          "command": "time-travel.startRecording",
          "when": "view == time-travel-timeline && !time-travel:recording",
          "group": "navigation"
        },
        {
          "command": "time-travel.stopRecording",
          "when": "view == time-travel-timeline && time-travel:recording",
          "group": "navigation"
        }
      ]
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run package",
    "compile": "webpack",
    "watch": "webpack --watch",
    "package": "webpack --mode production --devtool hidden-source-map",
    "compile-tests": "tsc -p . --outDir out",
    "watch-tests": "tsc -p . -w --outDir out",
    "pretest": "npm run compile-tests && npm run compile && npm run lint",
    "lint": "eslint src --ext ts",
    "test": "node ./out/test/runTest.js"
  },
  "devDependencies": {
    "@types/diff": "^7.0.2",
    "@types/glob": "^8.1.0",
    "@types/mocha": "^10.0.1",
    "@types/node": "20.2.5",
    "@types/react": "^18.2.0",
    "@types/react-dom": "^18.2.0",
    "@types/vscode": "^1.80.0",
    "@typescript-eslint/eslint-plugin": "^5.59.8",
    "@typescript-eslint/parser": "^5.59.8",
    "@vscode/test-electron": "^2.3.2",
    "css-loader": "^6.8.1",
    "eslint": "^8.41.0",
    "glob": "^8.1.0",
    "mocha": "^10.2.0",
    "style-loader": "^3.3.3",
    "ts-loader": "^9.4.3",
    "typescript": "^5.1.3",
    "webpack": "^5.85.0",
    "webpack-cli": "^5.1.1"
  },
  "dependencies": {
    "diff": "^5.1.0",
    "immer": "^10.0.2",
    "lucide-react": "^0.263.1",
    "react": "^18.2.0",
    "react-dom": "^18.2.0"
  }
}
